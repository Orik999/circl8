# =========================================================
# Project Circl8 .gitignore
# Keep generated secrets, runtime state, logs, backups,
# local notes, and build artifacts out of Git.
# =========================================================

# ---------------------------------------------------------
# Environment / secrets
# ---------------------------------------------------------
.env
*.env
!.env.example

secrets/
**/secrets/

*.key
*.pem
id_rsa
id_ed25519

# ---------------------------------------------------------
# Runtime data / app state
# ---------------------------------------------------------
appdata/
**/appdata/

acme/
**/acme/
acme.json
**/acme.json
docker/traefik/acme/acme.json

# ---------------------------------------------------------
# Backups / logs / dumps
# ---------------------------------------------------------
backups/
**/backups/

*.bak
*.backup
*.dump
*.sql
*.log

# ---------------------------------------------------------
# Archives / local exports
# ---------------------------------------------------------
*.zip
*.tar
*.tar.gz
*.tgz
*.7z

# ---------------------------------------------------------
# OS / editor
# ---------------------------------------------------------
.DS_Store
Thumbs.db

.vscode/
.idea/

# ---------------------------------------------------------
# Node / Astro
# ---------------------------------------------------------
node_modules/
dist/
.astro/
.cache/

# ---------------------------------------------------------
# Python
# ---------------------------------------------------------
__pycache__/
*.pyc

# ---------------------------------------------------------
# Manually managed local content
# ---------------------------------------------------------
circl8_content/
myHelpNotes/
AGENTS.md
